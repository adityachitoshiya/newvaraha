# Backend API URL Configuration
# Copy this file to .env.local and configure your backend URL

# For local development (default):
NEXT_PUBLIC_API_URL=http://localhost:8000

# For production deployment, change to your live backend URL:
# Example: If your backend is hosted at api.varahajewels.in
# NEXT_PUBLIC_API_URL=https://api.varahajewels.in
# Or if backend is on same domain with /api path:
# NEXT_PUBLIC_API_URL=https://www.varahajewels.in/api

# Note: NEXT_PUBLIC_ prefix makes this variable accessible in the browser
# After creating .env.local, restart the dev server (npm run dev)
