# ===================================
# DATABASE CONFIGURATION
# ===================================
# PostgreSQL Database URL (Supabase or AWS RDS)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:5432/varahajewels

# ===================================
# SUPABASE CONFIGURATION
# ===================================
# Supabase Project URL and Service Role Key
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here

# ===================================
# EMAIL NOTIFICATIONS (Optional)
# ===================================
# SMTP credentials for sending order notifications
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
ADMIN_EMAIL=admin@varahajewels.com

# ===================================
# TELEGRAM NOTIFICATIONS (Optional)
# ===================================
# Telegram Bot for order alerts
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ===================================
# SHIPPING INTEGRATION (Optional)
# ===================================
# RapidShyp API Key for shipping
RAPIDSHYP_API_KEY=your-rapidshyp-api-key

# ===================================
# CLOUDINARY (Optional - for image uploads)
# ===================================
# Cloudinary credentials (if using Cloudinary instead of Supabase Storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===================================
# JWT SECRET (Required)
# ===================================
# Secret key for JWT token generation
# Generate a secure random string: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# ===================================
# NOTES
# ===================================
# 1. Copy this file to .env in the root directory (not in backend/)
# 2. Fill in your actual credentials
# 3. Never commit .env file to git (it's in .gitignore)
# 4. For production, set these as environment variables in your hosting platform
